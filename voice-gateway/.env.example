PORT=8080
NODE_ENV=development

# Public HTTPS URL of this service, for example:
# https://voice.xorvian.com
# https://your-ngrok-domain.ngrok-free.app
PUBLIC_BASE_URL=

# Optional shared token for Twilio webhook and stream URLs.
# Add ?token=... to the Twilio voice webhook URL.
VOICE_GATEWAY_TOKEN=change-this-long-random-token

OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_TRANSCRIPTION_MODEL=whisper-1

ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=ugPTAEnkrnbtfSNMzaSY
ELEVENLABS_DEFAULT_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=ulaw_8000
ELEVENLABS_OPTIMIZE_STREAMING_LATENCY=3

# Existing PHP API base URL.
XORVIAN_API_BASE=https://aliportfolio.org/xorvian/backend/api
XORVIAN_SHARED_SECRET=xorvian_n8n_secret

# Canada-first defaults. Restaurant settings from PHP can override these.
DEFAULT_LANGUAGE=en-CA
DEFAULT_TIMEZONE=America/Toronto
DEFAULT_CURRENCY=CAD
DEFAULT_COUNTRY=Canada

# Keep logs concise in production. Use debug locally.
LOG_LEVEL=info
